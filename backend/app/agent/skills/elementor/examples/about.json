{
  "meta": {
    "section_type": "about",
    "layout": "single",
    "scalar_slots": ["eyebrow", "heading", "text", "cta_text", "accent_color", "background_color", "heading_color"],
    "item_slots": []
  },
  "template": {
    "id": "abt00000",
    "elType": "section",
    "settings": {
      "layout": "boxed",
      "content_width": { "unit": "px", "size": 900 },
      "background_background": "classic",
      "background_color": "{{background_color}}",
      "padding": { "unit": "px", "top": "80", "right": "20", "bottom": "80", "left": "20", "isLinked": false }
    },
    "elements": [
      {
        "id": "abtcol00",
        "elType": "column",
        "settings": {
          "_column_size": 100,
          "_inline_size": null,
          "_padding": { "unit": "px", "top": "50", "right": "50", "bottom": "50", "left": "50", "isLinked": false },
          "_border_radius": { "unit": "px", "top": "12", "right": "12", "bottom": "12", "left": "12", "isLinked": true },
          "_box_shadow_box_shadow_type": "yes",
          "_box_shadow_box_shadow": { "horizontal": 0, "vertical": 8, "blur": 24, "spread": 0, "color": "rgba(0,0,0,0.08)" }
        },
        "elements": [
          {
            "id": "abteyb00",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{eyebrow}}", "header_size": "h6", "align": "center", "title_color": "{{accent_color}}" }
          },
          {
            "id": "abthdg00",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{heading}}", "header_size": "h2", "align": "center", "title_color": "{{heading_color}}" }
          },
          {
            "id": "abttxt00",
            "elType": "widget",
            "widgetType": "text-editor",
            "settings": { "editor": "{{text}}", "align": "center", "text_color": "{{heading_color}}" }
          },
          {
            "id": "abtcta00",
            "elType": "widget",
            "widgetType": "button",
            "settings": { "text": "{{cta_text}}", "align": "center", "background_color": "{{accent_color}}", "link": { "url": "#", "is_external": "", "nofollow": "" } }
          }
        ]
      }
    ]
  }
}
