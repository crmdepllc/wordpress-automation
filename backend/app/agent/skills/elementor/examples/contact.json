{
  "meta": {
    "section_type": "contact",
    "layout": "single",
    "scalar_slots": ["heading", "subheading", "email", "phone", "background_color", "heading_color"],
    "item_slots": []
  },
  "template": {
    "id": "cnt0000",
    "elType": "section",
    "settings": {
      "layout": "boxed",
      "content_width": { "unit": "px", "size": 800 },
      "background_background": "classic",
      "background_color": "{{background_color}}",
      "padding": { "unit": "px", "top": "60", "right": "20", "bottom": "60", "left": "20", "isLinked": false }
    },
    "elements": [
      {
        "id": "cntcol0",
        "elType": "column",
        "settings": { "_column_size": 100, "_inline_size": null },
        "elements": [
          {
            "id": "cnthdg0",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{heading}}", "header_size": "h2", "align": "center", "title_color": "{{heading_color}}" }
          },
          {
            "id": "cntsub0",
            "elType": "widget",
            "widgetType": "text-editor",
            "settings": { "editor": "{{subheading}}", "align": "center", "text_color": "{{heading_color}}" }
          },
          {
            "id": "cnteml0",
            "elType": "widget",
            "widgetType": "icon-list",
            "settings": {
              "icon_list": [
                { "_id": "cnteml1", "text": "{{email}}", "selected_icon": { "value": "fas fa-envelope", "library": "fa-solid" } },
                { "_id": "cntphn1", "text": "{{phone}}", "selected_icon": { "value": "fas fa-phone", "library": "fa-solid" } }
              ],
              "view": "inline",
              "align": "center"
            }
          }
        ]
      }
    ]
  }
}
