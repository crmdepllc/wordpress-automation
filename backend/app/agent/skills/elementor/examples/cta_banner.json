{
  "meta": {
    "section_type": "cta_banner",
    "layout": "single",
    "scalar_slots": ["heading", "subheading", "cta_text", "background_color", "heading_color"],
    "item_slots": []
  },
  "template": {
    "id": "ctb00000",
    "elType": "section",
    "settings": {
      "layout": "full_width",
      "background_background": "classic",
      "background_color": "{{background_color}}",
      "padding": { "unit": "px", "top": "60", "right": "20", "bottom": "60", "left": "20", "isLinked": false }
    },
    "elements": [
      {
        "id": "ctbcol00",
        "elType": "column",
        "settings": { "_column_size": 100, "_inline_size": null },
        "elements": [
          {
            "id": "ctbhdg00",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{heading}}", "header_size": "h2", "align": "center", "title_color": "{{heading_color}}" }
          },
          {
            "id": "ctbsub00",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{subheading}}", "header_size": "h4", "align": "center", "title_color": "{{heading_color}}" }
          },
          {
            "id": "ctbcta00",
            "elType": "widget",
            "widgetType": "button",
            "settings": { "text": "{{cta_text}}", "align": "center", "size": "lg", "link": { "url": "#", "is_external": "", "nofollow": "" } }
          }
        ]
      }
    ]
  }
}
