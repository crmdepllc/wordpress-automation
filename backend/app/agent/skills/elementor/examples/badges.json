{
  "meta": {
    "section_type": "badges",
    "layout": "grid",
    "scalar_slots": ["eyebrow", "heading", "accent_color", "background_color", "heading_color"],
    "item_slots": ["label", "icon"]
  },
  "template": {
    "id": "bdg00000",
    "elType": "section",
    "settings": {
      "layout": "full_width",
      "background_background": "classic",
      "background_color": "{{background_color}}",
      "padding": { "unit": "px", "top": "60", "right": "20", "bottom": "60", "left": "20", "isLinked": false }
    },
    "elements": [
      {
        "id": "bdgoutr0",
        "elType": "column",
        "settings": { "_column_size": 100, "_inline_size": null },
        "elements": [
          {
            "id": "bdgeyb00",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{eyebrow}}", "header_size": "h6", "align": "center", "title_color": "{{accent_color}}" }
          },
          {
            "id": "bdghdg00",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{heading}}", "header_size": "h2", "align": "center", "title_color": "{{heading_color}}" }
          },
          {
            "id": "bdggrd00",
            "elType": "section",
            "settings": {
              "layout": "boxed",
              "gap": "default",
              "margin": { "unit": "px", "top": "30", "right": "0", "bottom": "0", "left": "0", "isLinked": false }
            },
            "elements": [
              {
                "id": "bdgcol00",
                "elType": "column",
                "settings": { "_column_size": 25, "_inline_size": null },
                "elements": [
                  {
                    "id": "bdgico00",
                    "elType": "widget",
                    "widgetType": "icon-box",
                    "settings": {
                      "title_text": "{{item.label}}",
                      "selected_icon": { "value": "{{item.icon}}", "library": "fa-solid" },
                      "position": "top",
                      "title_size": "h5",
                      "view": "stacked",
                      "shape": "circle",
                      "primary_color": "{{accent_color}}",
                      "secondary_color": "#ffffff"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
