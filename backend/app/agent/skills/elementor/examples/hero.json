{
  "meta": {
    "section_type": "hero",
    "layout": "single",
    "scalar_slots": ["eyebrow", "heading", "subheading", "cta_text", "background_color", "heading_color", "accent_color"],
    "item_slots": []
  },
  "template": {
    "id": "hero000",
    "elType": "section",
    "settings": {
      "layout": "boxed",
      "content_width": { "unit": "px", "size": 1140 },
      "background_background": "classic",
      "background_color": "{{background_color}}",
      "padding": { "unit": "px", "top": "100", "right": "20", "bottom": "100", "left": "20", "isLinked": false }
    },
    "elements": [
      {
        "id": "herocol",
        "elType": "column",
        "settings": { "_column_size": 100, "_inline_size": null },
        "elements": [
          {
            "id": "heroeyb0",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{eyebrow}}", "header_size": "h6", "align": "center", "title_color": "{{accent_color}}" }
          },
          {
            "id": "herohdg",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{heading}}", "header_size": "h1", "align": "center", "title_color": "{{heading_color}}" }
          },
          {
            "id": "herosub",
            "elType": "widget",
            "widgetType": "heading",
            "settings": { "title": "{{subheading}}", "header_size": "h3", "align": "center", "title_color": "{{heading_color}}" }
          },
          {
            "id": "herocta",
            "elType": "widget",
            "widgetType": "button",
            "settings": { "text": "{{cta_text}}", "align": "center", "size": "lg", "background_color": "{{accent_color}}", "link": { "url": "#", "is_external": "", "nofollow": "" } }
          }
        ]
      }
    ]
  }
}
