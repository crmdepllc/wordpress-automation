{
  "meta": {
    "section_type": "features",
    "layout": "grid",
    "scalar_slots": [],
    "item_slots": ["title", "text", "icon"]
  },
  "template": {
    "id": "feat000",
    "elType": "section",
    "settings": { "layout": "boxed", "gap": "default" },
    "elements": [
      {
        "id": "featcol",
        "elType": "column",
        "settings": { "_column_size": 33, "_inline_size": null },
        "elements": [
          {
            "id": "featico",
            "elType": "widget",
            "widgetType": "icon-box",
            "settings": {
              "title_text": "{{item.title}}",
              "description_text": "{{item.text}}",
              "selected_icon": { "value": "{{item.icon}}", "library": "fa-solid" },
              "position": "top",
              "title_size": "h3"
            }
          }
        ]
      }
    ]
  }
}
