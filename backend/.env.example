# Backend environment — copy to backend/.env and fill in. NEVER commit .env.
# Secrets (API keys, DB credentials) belong here, never in source.

# --- Anthropic / Claude (required for the agent to run) ---
ANTHROPIC_API_KEY=

# Model routing (defaults shown; override only if needed)
ORCHESTRATOR_MODEL=claude-opus-4-8
FAST_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=1024

# --- Data services (defaults match docker-compose) ---
DATABASE_URL=postgresql+asyncpg://wpa:wpa@postgres:5432/wpa
REDIS_URL=redis://redis:6379/0

# --- Credential encryption (required to store/read WP site credentials) ---
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Local WordPress CLI container name used by the WP-CLI docker-exec transport in dev.
WP_LOCAL_CONTAINER=wordpress-automation-wpcli-1

# --- Orchestration / Celery (defaults match docker-compose) ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- LangSmith tracing (optional; leave blank to disable) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=wordpress-automation

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:3000
